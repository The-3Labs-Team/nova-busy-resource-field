{
    "name": "the-3labs-team/nova-busy-resource-field",
    "description": "A Laravel Nova field.",
    "keywords": [
        "laravel",
        "nova"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3|^8.4",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "outl1ne/nova-translations-loader": "^5.0"
    },
    "require-dev": {
        "laravel/nova": "^5.0",
        "orchestra/testbench": "^10.9",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "The3labsTeam\\NovaBusyResourceField\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\": "tests/Fixtures/App/",
            "Tests\\": "tests/"
        },
        "files": [
            "tests/Stubs/nova.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "The3labsTeam\\NovaBusyResourceField\\FieldServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "vendor/bin/phpunit --configuration phpunit.xml.dist"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "composer",
            "url": "https://nova.laravel.com"
        }
    ]
}
